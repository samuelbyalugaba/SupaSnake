{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Neon Snake game.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "username": {
          "type": "string",
          "description": "The user's username."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "username"
      ]
    },
    "HighScore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HighScore",
      "type": "object",
      "description": "Represents a high score achieved by a user in the Neon Snake game.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the high score entry."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the user who achieved the score."
        },
        "username": {
          "type": "string",
          "description": "The username of the player who achieved the score."
        },
        "score": {
          "type": "number",
          "description": "The score achieved by the user."
        },
        "timestamp": {
          "type": "string",
          "description": "The timestamp of when the score was achieved.",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "username",
        "score",
        "timestamp"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profile information. Owned by the user."
        }
      },
      {
        "path": "/highscores/{highScoreId}",
        "definition": {
          "entityName": "HighScore",
          "schema": {
            "$ref": "#/backend/entities/HighScore"
          },
          "description": "Stores high scores for the global leaderboard. Writable by any authenticated user, readable by all."
        }
      }
    ]
  }
}
