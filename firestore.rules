/**
 * @fileoverview Firestore Security Rules for Neon Snake Game
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and high scores.
 *
 * Data Structure:
 * - User profiles are stored in `/users/{userId}`.
 * - A global leaderboard of high scores is stored in `/highscores/{scoreId}`.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own profile data.
 * - Any authenticated user can write to the highscores collection to submit their score.
 * - All users (authenticated or not) can read the highscores for the leaderboard.
 * - The ruleset relies on path-based authorization for user profiles.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow read, update, delete: if isOwner();
      allow create: if isOwner() && request.resource.data.id == request.auth.uid;
      allow list: if false; // User listing is not allowed.
    }

    /**
     * @description Controls access to the global high score leaderboard.
     * @path /highscores/{highScoreId}
     */
    match /highscores/{highScoreId} {
      // Anyone can read the leaderboard
      allow get, list: if true;

      // Only authenticated users can create a new high score
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Scores cannot be updated or deleted by clients
      allow update, delete: if false;
    }
  }
}
