
/**
 * @fileoverview Firestore Security Rules for Neon Snake Game
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and high scores.
 *
 * Data Structure:
 * - User profiles are stored in `/users/{userId}`.
 * - A global leaderboard of high scores is stored in `/highscores/{userId}`.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own profile data.
 * - Authenticated users can only write to their own high score document.
 * - All users (authenticated or not) can read the highscores for the leaderboard.
 * - The ruleset relies on path-based authorization for user profiles and high scores.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow read, update, delete: if isOwner();
      allow create: if isOwner() && request.resource.data.id == request.auth.uid;
      allow list: if false; // User listing is not allowed.
    }

    /**
     * @description Controls access to the global high score leaderboard.
     * Each user can have one document, with the doc ID being their UID.
     * @path /highscores/{userId}
     */
    match /highscores/{userId} {
      // Anyone can read the leaderboard
      allow get, list: if true;

      // A user can only write to their own score document.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

    